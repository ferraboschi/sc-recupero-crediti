# FatturaPro API Configuration
FATTURAPRO_API_URL=https://cloud.fatturapro.click
FATTURAPRO_API_KEY=your_fatturapro_api_key_here
FATTURAPRO_DOMAIN=yourdomain.com

# Fattura24 API Configuration (Legacy)
FATTURA24_API_KEY=your_fattura24_api_key_here

# Shopify Configuration
SHOPIFY_STORE_URL=https://yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token_here
SHOPIFY_API_VERSION=2026-01
SHOPIFY_PIVA_FIELD=address2

# Twilio / WhatsApp Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER_BUSINESS=whatsapp:+1234567890
TWILIO_WHATSAPP_NUMBER_RECOVERY=whatsapp:+0987654321
TWILIO_WEBHOOK_URL=https://yourapp.com/api/webhooks/twilio

# Application Configuration
DATABASE_PATH=data/sc_recupero.db
TIMEZONE=Europe/Rome
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=30
